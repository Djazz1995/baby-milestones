{
  "expo": {
    "name": "Baby Milestones",
    "slug": "baby-milestones",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "babymilestones",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.babymilestones.app",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Baby Milestones uses the camera so you can capture photos and videos of your child's moments.",
        "NSMicrophoneUsageDescription": "Baby Milestones uses the microphone to record voice notes and videos for your child's timeline.",
        "NSPhotoLibraryUsageDescription": "Baby Milestones needs access to your photos so you can add existing pictures and videos to the timeline.",
        "NSPhotoLibraryAddUsageDescription": "Baby Milestones saves exported photos and videos to your library."
      }
    },
    "android": {
      "package": "com.babymilestones.app",
      "permissions": ["CAMERA", "RECORD_AUDIO", "READ_MEDIA_IMAGES", "READ_MEDIA_VIDEO"],
      "adaptiveIcon": {
        "backgroundColor": "#F1F5F4",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F1F5F4",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
