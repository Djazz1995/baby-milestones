# Baby Milestones — copy to .env and fill in.
# EXPO_PUBLIC_ vars are inlined into the client bundle; never put server secrets here.

# Payload CMS API base URL (REST/GraphQL). The app reads/writes through this.
EXPO_PUBLIC_PAYLOAD_API_URL=http://localhost:3000/api

# ImageKit URL endpoint for media delivery.
EXPO_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
